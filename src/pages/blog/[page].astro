---
/**
 * 分页文章列表页 - 处理第2页及以后的路由
 * 路由: /blog/2 -> 第2页, /blog/3 -> 第3页, etc.
 */
import BlogListPagination from '../../components/BlogListPagination';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllPostSummaries, getUniqueTags, POSTS_PER_PAGE } from '../../utils/posts';

export function getStaticPaths() {
  // 支持最多10页
  return [2, 3, 4, 5, 6, 7, 8, 9, 10].map((pageNum) => ({
    params: { page: String(pageNum) },
    props: { pageNum },
  }));
}

const { pageNum } = Astro.props;

// 获取所有文章
const posts = await getCollection('blog');
const allPosts = getAllPostSummaries(posts);
const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);

// 如果请求的页码超过总页数，显示空列表
const startIndex = (pageNum - 1) * POSTS_PER_PAGE;
const pagePosts = pageNum <= totalPosts
  ? allPosts.slice(startIndex, startIndex + POSTS_PER_PAGE)
  : [];

// 获取所有标签
const uniqueTags = getUniqueTags(allPosts);
---

<BaseLayout title="文章 - DESIGNER.BLOG" description="我的技术博客">
  <BlogListPagination
    client:load
    posts={pagePosts}
    tags={uniqueTags}
    currentPage={pageNum}
    totalPages={totalPages}
    basePath="/blog"
  />
</BaseLayout>
